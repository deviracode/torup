# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Reminder dispatch + Google Calendar sync
# In production, leave ENABLE_INPROCESS_REMINDER_SCHEDULER unset and rely on cron jobs
# (Railway dashboard or external cron service) hitting:
#   POST /api/internal/reminders/tick        (every 5 min)
#   POST /api/internal/google-calendar/sync   (every 15 min)
# For local dev, set this to "true" so both schedulers fire from in-process setInterval.
ENABLE_INPROCESS_REMINDER_SCHEDULER=true
# Shared secret required by POST /api/internal/reminders/tick (header X-Internal-Secret).
INTERNAL_SECRET=changeme

# Google Calendar integration
# OAuth 2.0 credentials from Google Cloud Console. Create them under
# APIs & Services > Credentials > OAuth 2.0 Client ID (Web application).
# GOOGLE_REDIRECT_URI should point to the frontend page that receives the code.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/he/dashboard/settings
